{
  "title": "Interpretable Vision — Overview",
  "panels": [
    {"type": "graph", "title": "Requêtes /predict (rate)", "targets": [{"expr": "rate(predict_requests_total[1m])"}]},
    {"type": "graph", "title": "Latence p95 (s)", "targets": [{"expr": "histogram_quantile(0.95, rate(predict_latency_seconds_bucket[5m]))"}]},
    {"type": "graph", "title": "Confiance moyenne", "targets": [{"expr": "rate(predict_confidence_sum[5m]) / rate(predict_confidence_count[5m])"}]},
    {"type": "graph", "title": "Stabilité des explications (moy.)", "targets": [{"expr": "rate(explanation_stability_sum[5m]) / rate(explanation_stability_count[5m])"}]}
  ]
}
